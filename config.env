# Azure Subscription and Resource Configuration

AZURE_SUBSCRIPTION_ID="a23fa87c-802c-4fdf-9e59-e3d7969bcf31"
AZURE_TENANT_ID="e7572e92-7aee-4713-a3c4-ba64888ad45f"
AZURE_RESOURCE_GROUP="rg-churn-ml-project"
AZURE_LOCATION="southeastasia"

# Azure ML Workspace Configuration
AZURE_WORKSPACE_NAME="churn-ml-workspace"

# Compute Resources
AZURE_COMPUTE_CLUSTER_NAME="cpu-cluster"
AZURE_PIPELINE_COMPUTE="cpu-cluster"
COMPUTE_CLUSTER_SIZE="Standard_DS2_v2"
MIN_NODES="0"
MAX_NODES="2"
AZURE_COMPUTE_INSTANCE_NAME="ci-notebooks"
COMPUTE_INSTANCE_SIZE="Standard_DS2_v2"
CREATE_COMPUTE_INSTANCE="true"

# Optional storage reference
# Not required by setup/setup.ps1 or setup/setup.sh. Use only for manual storage workflows/troubleshooting.
AZURE_STORAGE_ACCOUNT="yourstorageaccount"
AZURE_STORAGE_CONTAINER="data"

# Optional repo-owned online inference capture proof
# Set these only when validating externalized inference capture against workspaceblobstore.
# INFERENCE_CAPTURE_STORAGE_CONNECTION_STRING="<workspace-blob-connection-string>"
# INFERENCE_CAPTURE_STORAGE_CONTAINER="<workspaceblobstore-container>"

# Azure Container Registry (ACR) Configuration
# ACR name must be globally unique (3-50 characters, alphanumeric only)
# Used for storing Docker images for Azure ML environments
AZURE_ACR_NAME="churnmlarc"
ACR_SKU="Basic"

# Project asset/model/deployment defaults live in configs/assets.yaml.
# Set DATA_*, MODEL_NAME, ENDPOINT_NAME, DEPLOYMENT_NAME, or AML_ONLINE_* here only
# when you intentionally need a local override.
